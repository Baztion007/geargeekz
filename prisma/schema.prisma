// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

model PriceAlert {
  id          String   @id @default(cuid())
  email       String
  productSlug String
  targetPrice String
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  @@unique([email, productSlug])
}

model UserReview {
  id          String   @id @default(cuid())
  productSlug String
  author      String
  rating      Float
  title       String
  content     String
  pros        String?
  cons        String?
  verified    Boolean  @default(false)
  helpful     Int      @default(0)
  createdAt   DateTime @default(now())
}

model AffiliateMerchantConfig {
  id            String   @id @default(cuid())
  merchantId    String   @unique
  name          String
  affiliateTag  String
  baseUrl       String
  urlTemplate   String
  enabled       Boolean  @default(true)
  priority      Int      @default(1)
  color         String   @default("#FF9900")
  icon          String   @default("shopping-bag")
  updatedAt     DateTime @updatedAt
}

model AffiliateGlobalSettings {
  id                  String   @id @default("default")
  linkStrategy        String   @default("direct")
  redirectPrefix      String   @default("/go/")
  nofollowEnabled     Boolean  @default(true)
  sponsoredEnabled    Boolean  @default(true)
  noopenerEnabled     Boolean  @default(true)
  openInNewTab        Boolean  @default(true)
  clickTracking       Boolean  @default(true)
  impressionTracking  Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  image           String
  gallery         String   @default("[]")
  excerpt         String
  category        String
  categorySlug    String
  subcategory     String   @default("")
  brand           String
  brandSlug       String
  features        String   @default("{}")
  pros            String   @default("[]")
  cons            String   @default("[]")
  rating          Float    @default(0)
  ratingBreakdown String   @default("{}")
  asin            String   @default("")
  merchant        String   @default("amazon")
  affiliateUrl    String   @default("")
  priceUrl        String   @default("")
  tags            String   @default("[]")
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime @default(now())
  authorSlug      String   @default("alex-rivera")
  reviewStatus    String   @default("new")
  bestFor         String   @default("[]")
  summary         String   @default("")
  fullReview      String   @default("")
  whoIsItFor      String   @default("")
  whoShouldSkip   String   @default("")
  specifications  String   @default("{}")
  relatedProducts String   @default("[]")
}

model CategoryDB {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  description  String
  image        String
  productCount Int     @default(0)
  featured     Boolean @default(false)
}

model BrandDB {
  slug         String @id
  name         String
  logo         String
  description  String
  founded      String?
  headquarters String?
  website      String?
  categories   String @default("[]")
  productCount Int    @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  ipAddress String?  @map("ip_address")

  @@map("contact_messages")
}