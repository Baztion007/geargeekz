# ─── Cloudflare / Production Environment Variables ─────────────────────────
#
# These MUST be set as Secrets in the Cloudflare Workers dashboard
# (Workers → geargeekz → Settings → Variables and Secrets)
#
# DO NOT commit real secrets to Git!
#
# Build commands:
#   cf:build   → opennextjs-cloudflare build
#   cf:deploy  → opennextjs-cloudflare build && opennextjs-cloudflare deploy
#   cf:preview → opennextjs-cloudflare build && opennextjs-cloudflare preview

# ─── Database (Turso / libSQL) ────────────────────────────────────────────
# REQUIRED: Use a Turso database URL (libsql:// or https://)
# Local file: URLs are NOT supported on Cloudflare Workers (ephemeral filesystem)
#
# 1. Create a Turso database: https://turso.tech
# 2. Get your database URL: turso db show <your-db-name> --url
# 3. Create an auth token: turso db tokens create <your-db-name>
DATABASE_URL=libsql://your-db-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# ─── Admin Authentication ─────────────────────────────────────────────────
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_SESSION_SECRET=your-random-secret-at-least-32-chars

# ─── Runtime ──────────────────────────────────────────────────────────────
# OpenNext sets NODE_ENV=production automatically during build
# You don't need to set this manually
# NODE_ENV=production

# ─── Site URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://geargeekz.com

# ─── Optional: Affiliate Tag Overrides ─────────────────────────────────────
# These override the default affiliate tags from the database
# NEXT_PUBLIC_AFFILIATE_TAG_AMAZON=
# NEXT_PUBLIC_AFFILIATE_TAG_WALMART=
# NEXT_PUBLIC_AFFILIATE_TAG_BESTBUY=
# NEXT_PUBLIC_AFFILIATE_TAG_TARGET=
# NEXT_PUBLIC_AFFILIATE_TAG_REI=
# NEXT_PUBLIC_AFFILIATE_TAG_BHPHOTO=
